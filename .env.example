# REPLITCLONE Environment Variables
# Copy this file to .env and fill in your actual values

# Gemini AI Studio API Key
# Generate one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth App Credentials
# Create an OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Flask secret key (use a long random string)
SECRET_KEY=change_this_to_a_random_secret_key
